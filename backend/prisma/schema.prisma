generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ProjectStatus {
  DRAFT
  ANALYZING
  READY
  HOOKS_READY
  SCRIPTS_READY
  MEDIA_READY
  EXPORT_READY
  FAILED
}

enum JobType {
  ANALYZE_WEBSITE
  GENERATE_CONCEPTS
  GENERATE_MEDIA
  SAVE_EXPORT
  GENERATE_HOOKS
  GENERATE_SCRIPTS
}

enum JobStatus {
  QUEUED
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
}

enum MediaType {
  IMAGE
  VIDEO
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  passwordHash      String
  name              String?
  role              UserRole       @default(USER)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  projects          Project[]
  allowedEmailsMade AllowedEmail[] @relation("AllowedEmailCreatedBy")
}

model AllowedEmail {
  id          String   @id @default(cuid())
  email       String   @unique
  createdAt   DateTime @default(now())
  createdById String?
  createdBy   User?    @relation("AllowedEmailCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
}

model Project {
  id                  String         @id @default(cuid())
  userId              String?
  user                User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  website             String
  normalizedWebsite   String
  status              ProjectStatus  @default(DRAFT)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  selectedConceptId   String?        @map("selectedHookId")
  selectedCharacterId String?        @map("selectedCharacterId")
  selectedCharacter   Json?          @map("selectedCharacter")
  selectedConcept     HookConcept?   @relation("ProjectSelectedConcept", fields: [selectedConceptId], references: [id], onDelete: SetNull)
  brandProfile        BrandProfile?
  websiteAnalysis     WebsiteAnalysis?
  concepts            HookConcept[]
  mediaAssets         MediaAsset[]
  exportState         ProjectExport?
  jobs                GenerationJob[]

  @@unique([userId, normalizedWebsite])
  @@index([userId, createdAt])
  @@index([userId, normalizedWebsite])
}

model BrandProfile {
  id                String   @id @default(cuid())
  projectId         String   @unique
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  brandName         String
  product           String
  audience          String
  audienceIdentity  String
  audienceStage     String
  emotionalDrivers  String[]
  fears             String[]
  realThoughts      String[]
  dailyMoments      String[]
  dreamOutcomes     String[]
  misconceptions    String[]
  objections        String[]
  proofPoints       String[]
  socialProofMoments String[]
  transformation    String
  uniqueMechanism   String
  conversationStarters String[]
  viralTriggers     String[]
  emotionalLanguage String[]
  forbiddenClaims   String[]
  ugcScenarios      String[]
  testimonials      String[]
  cta               String
  summary           String
  campaignStrategy  Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model WebsiteAnalysis {
  id            String   @id @default(cuid())
  projectId     String   @unique
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceUrl     String
  rootDomain    String
  discoveredUrls Json
  rankedPages   Json
  selectedPages Json
  crawlSummary  Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model HookConcept {
  id                    String    @id @default(cuid())
  projectId             String
  project               Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  angle                 String
  hookText              String
  hookImagePrompt       String
  demoOverlayText       String
  videoDirection        String
  targetDurationLabel   String
  targetDurationSeconds Int
  score                 Int
  scoreLabel            String
  rationale             String
  generatedImageUrl     String?
  generatedVideoUrl     String?
  sortOrder             Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  selectedByProjects    Project[] @relation("ProjectSelectedConcept")
  mediaAssets           MediaAsset[]

  @@index([projectId, sortOrder])
  @@map("HookDraft")
}

model MediaAsset {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conceptId   String?      @map("scriptDraftId")
  concept     HookConcept? @relation(fields: [conceptId], references: [id], onDelete: SetNull)
  type        MediaType
  provider    String
  providerId  String?
  url         String
  mimeType    String?
  metadata    Json?
  createdAt   DateTime     @default(now())

  @@index([projectId, createdAt])
}

model ProjectExport {
  id         String   @id @default(cuid())
  projectId  String   @unique
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  settings   Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Creator {
  id                  String       @id @default(cuid())
  name                String
  description         String?
  baseImageUrl        String
  baseImageProvider   String
  baseImageProviderId String?
  baseImageMimeType   String?
  baseImageMetadata   Json?
  sortOrder           Int          @default(0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  clips               CreatorClip[]

  @@index([sortOrder, createdAt])
}

model CreatorClip {
  id          String   @id @default(cuid())
  creatorId   String
  creator     Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  title       String?
  url         String
  provider    String
  providerId  String?
  mimeType    String?
  metadata    Json?
  tags        String[]
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([creatorId, sortOrder])
  @@index([createdAt])
}

model GenerationJob {
  id             String      @id @default(cuid())
  projectId      String
  project        Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type           JobType
  status         JobStatus   @default(QUEUED)
  progress       Int         @default(0)
  progressMessage String?
  input          Json
  result         Json?
  errorMessage   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([projectId, createdAt])
  @@index([status, createdAt])
}
