  "scenes": [
    {
      "characterId": "cmoto5ygp000110hz7mp8jhiu",
      "characterName": "Morty Smith",
      "text": "Wait, how do I reverse this linked list thingy?",
      "audioUrl": "/public/voiceovers/1779864726641/line_0.mp3",
      "start": 0,
      "duration": 2.768875,
      "imageUrl": "/public/characters/morty smith.png"
    },
    {
      "characterId": "cmoto799n000210hz2cbyjiuq",
      "characterName": "Peter Griffin",
      "text": "Oh, just spin around in a circle, Morty!  That's what I do when I'm lost!",
      "audioUrl": "/public/voiceovers/1779864726641/line_1.mp3",
      "start": 2.768875,
      "duration": 4.937062,
      "imageUrl": "/public/characters/peter griffin.png"
    },
    {
      "characterId": "cmoto5ygp000110hz7mp8jhiu",
      "characterName": "Morty Smith",
      "text": "That's not helping, Peter!  I need to know how to reverse the pointers!",
      "audioUrl": "/public/voiceovers/1779864726641/line_2.mp3",
      "start": 7.7059370000000005,
      "duration": 4.284,
      "imageUrl": "/public/characters/morty smith.png"
    },
    {
      "characterId": "cmoto799n000210hz2cbyjiuq",
      "characterName": "Peter Griffin",
      "text": "Okay, okay...  You gotta change the next pointers, Morty.  Make them point backwards!",
      "audioUrl": "/public/voiceovers/1779864726641/line_3.mp3",
      "start": 11.989937000000001,
      "duration": 5.041562,
      "imageUrl": "/public/characters/peter griffin.png"
    },
    {
      "characterId": "cmoto5ygp000110hz7mp8jhiu",
      "characterName": "Morty Smith",
      "text": "That's it?  Just change the pointers?  But how do I keep track?",
      "audioUrl": "/public/voiceovers/1779864726641/line_4.mp3",
      "start": 17.031499,
      "duration": 3.9705,
      "imageUrl": "/public/characters/morty smith.png"
    },
    {
      "characterId": "cmoto799n000210hz2cbyjiuq",
      "characterName": "Peter Griffin",
      "text": "Use three pointers, Morty!  One for the current node, one for the previous node, and one for the next node.  Then, just iterate through the list and reverse the pointers!",
      "audioUrl": "/public/voiceovers/1779864726641/line_5.mp3",
      "start": 21.001999,
      "duration": 9.639125,
      "imageUrl": "/public/characters/peter griffin.png"
    },
    {
      "characterId": "cmoto5ygp000110hz7mp8jhiu",
      "characterName": "Morty Smith",
      "text": "Whoa, that makes sense!  I think I get it now!  Let me try it!",
      "audioUrl": "/public/voiceovers/1779864726641/line_6.mp3",
      "start": 30.641124,
      "duration": 4.466875,
      "imageUrl": "/public/characters/morty smith.png"
    },
    {
      "characterId": "cmoto799n000210hz2cbyjiuq",
      "characterName": "Peter Griffin",
      "text": "Oh, great...  Now you're gonna break the list and we'll have to fix it again!",
      "audioUrl": "/public/voiceovers/1779864726641/line_7.mp3",
      "start": 35.107999,
      "duration": 4.623563,
      "imageUrl": "/public/characters/peter griffin.png"
    },
    {
      "characterId": "cmoto5ygp000110hz7mp8jhiu",
      "characterName": "Morty Smith",
      "text": "Ha!  I did it, Peter!  The list is reversed!  I'm a genius!",
      "audioUrl": "/public/voiceovers/1779864726641/line_8.mp3",
      "start": 39.731562,
      "duration": 4.571313,
      "imageUrl": "/public/characters/morty smith.png"
    }
  ],
