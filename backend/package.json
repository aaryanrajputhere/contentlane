{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch src --exec ts-node src/index.ts",
    "worker:dev": "nodemon --watch src --exec ts-node src/worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "allow-email": "ts-node src/scripts/allow-email.ts add",
    "disallow-email": "ts-node src/scripts/allow-email.ts remove",
    "jobs:failed": "ts-node src/scripts/jobs.ts failed",
    "jobs:retry": "ts-node src/scripts/jobs.ts retry",
    "test": "node --test dist/tests/*.test.js",
    "check": "npm run prisma:generate && prisma validate && npm run typecheck && npm run build && npm test"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@huggingface/inference": "^4.13.18",
    "@mendable/firecrawl-js": "^4.25.2",
    "@bull-board/api": "^6.12.0",
    "@bull-board/express": "^6.12.0",
    "@prisma/client": "^5.22.0",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.41.9",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "form-data": "4.0.6",
    "helmet": "^8.1.0",
    "ioredis": "5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "openai": "^6.35.0",
    "pino": "^9.7.0",
    "pino-http": "^10.4.0",
    "ws": "8.21.0",
    "zod": "^3.24.2"
  }
}
